PORT=4000

# PostgreSQL (Laragon-hosted). Update credentials/db name to match your local setup.
DATABASE_URL="postgresql://postgres:@localhost:5432/helpdesk?schema=public"

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-32-chars-min
BETTER_AUTH_URL=http://localhost:4000

# Seed admin (used by `bun run db:seed`)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password123

# ANTHROPIC_API_KEY=
