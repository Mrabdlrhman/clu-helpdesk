{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "prisma": "prisma",
    "db:generate": "prisma generate",
    "db:seed": "bun run prisma/seed.ts"
  },
  "dependencies": {
    "@helpdesk/core": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/bun": "^1.3.0",
    "typescript": "^5.6.3"
  }
}
